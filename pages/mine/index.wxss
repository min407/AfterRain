/* 我的页面 v2 - 档案 · 日历 · 设置 */
.container {
  min-height: 100vh;
  background: linear-gradient(168deg, #F4F0FF 0%, #EDF5FF 60%, #F0F8FF 100%);
  padding-bottom: 40px;
}

/* ——— 用户 Banner ——— */
.user-banner {
  background: linear-gradient(135deg, #9B8EC4 0%, #8EC5FC 100%);
  padding: 52px 24px 28px;
  display: flex;
  align-items: center;
  gap: 16px;
}
.avatar-wrap {
  width: 60px; height: 60px;
  background: rgba(255,255,255,0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px solid rgba(255,255,255,0.5);
  flex-shrink: 0;
}
.avatar { font-size: 30px; }
.user-name {
  font-size: 20px;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 5px;
  letter-spacing: 0.5px;
}
.user-sub {
  font-size: 13px;
  color: rgba(255,255,255,0.78);
}

/* ——— 数据概览条 ——— */
.stats-strip {
  background: #FFFFFF;
  margin: -16px 16px 20px;
  border-radius: 20px;
  padding: 20px 8px;
  display: flex;
  align-items: center;
  box-shadow: 0 4px 16px rgba(155,142,196,0.14), 0 12px 32px rgba(155,142,196,0.07);
  position: relative;
  z-index: 1;
}
.strip-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.strip-sep {
  width: 1px; height: 34px;
  background: #EDE8F8;
}
.strip-num {
  font-size: 28px;
  font-weight: 700;
  color: #2D2B55;
  line-height: 1;
  margin-bottom: 6px;
}
.strip-streak { color: #7DD3A8; }
.strip-label {
  font-size: 12px;
  color: #B0B0CC;
  letter-spacing: 0.5px;
}

/* ——— Section 通用 ——— */
.section {
  margin: 0 16px 20px;
}
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10px;
  padding: 0 2px;
}
.section-title {
  font-size: 16px;
  font-weight: 700;
  color: #2D2B55;
  letter-spacing: 0.5px;
  position: relative;
  padding-left: 10px;
}
.section-title::before {
  content: '';
  position: absolute;
  left: 0; top: 50%;
  transform: translateY(-50%);
  width: 3px; height: 16px;
  background: linear-gradient(180deg, #9B8EC4 0%, #8EC5FC 100%);
  border-radius: 2px;
}
.section-action {
  font-size: 13px;
  color: #9B8EC4;
  font-weight: 500;
}

/* ——— 故事档案卡片 ——— */
.story-card {
  background: #FFFFFF;
  border-radius: 18px;
  padding: 18px 18px;
  box-shadow: 0 2px 10px rgba(155,142,196,0.1), 0 6px 20px rgba(155,142,196,0.06);
}
.story-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 16px;
}
.stag {
  font-size: 13px;
  font-weight: 500;
  padding: 5px 12px;
  border-radius: 20px;
}
.stag-scene      { background: #F0ECFF; color: #7468A8; }
.stag-duration   { background: #EDF6FF; color: #5090CC; }
.stag-initiator  { background: #FFF4EC; color: #C07840; }

.story-text-block {
  margin-bottom: 12px;
  padding: 12px 14px;
  background: #FAFAFA;
  border-radius: 12px;
}
.story-field-label {
  font-size: 12px;
  color: #C0BCCE;
  margin-bottom: 4px;
  letter-spacing: 0.5px;
}
.story-field-text {
  font-size: 14px;
  color: #4A4870;
  line-height: 1.6;
}
.story-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24px 0;
}
.empty-icon-s { font-size: 36px; margin-bottom: 10px; }
.empty-text-s { font-size: 14px; color: #C0BCCE; }

/* ——— 打卡日历 ——— */
.cal-nav {
  display: flex;
  align-items: center;
  gap: 8px;
}
.nav-btn {
  width: 28px; height: 28px;
  background: #F0ECFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  color: #9B8EC4;
  font-weight: 700;
  line-height: 1;
}
.cal-month {
  font-size: 14px;
  color: #6B6B8D;
  font-weight: 600;
}
.cal-card {
  background: #FFFFFF;
  border-radius: 18px;
  padding: 16px;
  box-shadow: 0 2px 10px rgba(155,142,196,0.1), 0 6px 20px rgba(155,142,196,0.06);
}
.cal-weekdays {
  display: flex;
  margin-bottom: 8px;
}
.cal-weekdays text {
  width: 14.28%;
  text-align: center;
  font-size: 12px;
  color: #C0BCCE;
  font-weight: 500;
}
.cal-days {
  display: flex;
  flex-wrap: wrap;
}
.cal-day {
  width: 14.28%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 5px 0;
  position: relative;
  min-height: 38px;
}
.day-num {
  font-size: 13px;
  color: #5A5880;
  font-weight: 500;
}
.day-empty .day-num { opacity: 0; }
.day-checked {
  background: #F0ECFF;
  border-radius: 10px;
}
.day-checked .day-num { color: #7468A8; font-weight: 700; }
.day-today .day-num {
  color: #9B8EC4;
  font-weight: 700;
}
.day-star {
  font-size: 9px;
  color: #FFD700;
  line-height: 1;
  text-shadow: 0 0 4px rgba(255,215,0,0.5);
}

/* ——— 设置 ——— */
.settings-card {
  background: #FFFFFF;
  border-radius: 18px;
  overflow: hidden;
  box-shadow: 0 2px 10px rgba(155,142,196,0.1), 0 6px 20px rgba(155,142,196,0.06);
}
.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 17px 18px;
}
.setting-left {
  display: flex;
  align-items: center;
  gap: 12px;
}
.setting-icon { font-size: 18px; }
.setting-text {
  font-size: 15px;
  color: #3D3A6A;
}
.setting-arrow {
  font-size: 20px;
  color: #C8C4D8;
}
.row-divider {
  height: 1px;
  background: #F4F0FC;
  margin: 0 18px;
}

/* ——— 底部 ——— */
.footer {
  text-align: center;
  font-size: 12px;
  color: #C8C4D8;
  margin-top: 24px;
  letter-spacing: 0.5px;
}
