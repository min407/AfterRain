<view class="container">
  <!-- 用户头部 Banner -->
  <view class="user-banner">
    <view class="avatar-wrap">
      <view class="avatar"><text>☀️</text></view>
    </view>
    <view class="user-meta">
      <view class="user-sub">会过去的，向前走吧</view>
    </view>
  </view>

  <!-- 数据概览 -->
  <view class="stats-strip">
    <view class="strip-item">
      <view class="strip-num">{{days}}</view>
      <view class="strip-label">陪伴天数</view>
    </view>
    <view class="strip-sep"></view>
    <view class="strip-item">
      <view class="strip-num">{{checkinCount}}</view>
      <view class="strip-label">本月记录</view>
    </view>
    <view class="strip-sep"></view>
    <view class="strip-item">
      <view class="strip-num strip-streak">{{streak}}</view>
      <view class="strip-label">连续坚持</view>
    </view>
  </view>

  <!-- 我的故事 -->
  <view class="section">
    <view class="section-header">
      <view class="section-title">我的故事</view>
      <view class="section-action" bindtap="editStory">重新聊聊 ›</view>
    </view>
    <view class="story-card" bindtap="editStory">
      <view class="story-filled" wx:if="{{story}}">
        <view class="story-tags">
          <view class="stag stag-scene">{{story.scene}}</view>
          <view class="stag stag-duration">{{story.duration}}</view>
          <view class="stag stag-initiator">{{story.initiator}}</view>
        </view>
        <view class="story-text-block" wx:if="{{story.current_thoughts}}">
          <view class="story-field-label">我的状态</view>
          <view class="story-field-text">{{story.current_thoughts}}</view>
        </view>
        <view class="story-text-block" wx:if="{{story.hardest_moment}}">
          <view class="story-field-label">最放不下的瞬间</view>
          <view class="story-field-text">{{story.hardest_moment}}</view>
        </view>
      </view>
      <view class="story-empty" wx:else>
        <view class="empty-icon-s">💌</view>
        <view class="empty-text-s">还没跟我说过你们的故事呢，来聊聊吧</view>
      </view>
    </view>
  </view>

  <!-- 成长足迹 -->
  <view class="section">
    <view class="section-header">
      <view class="section-title">我的足迹</view>
      <view class="cal-nav">
        <view class="nav-btn" bindtap="prevMonth">‹</view>
        <view class="cal-month">{{currentMonth}}</view>
        <view class="nav-btn" bindtap="nextMonth">›</view>
      </view>
    </view>
    <view class="cal-card">
      <view class="cal-weekdays">
        <text>日</text><text>一</text><text>二</text><text>三</text>
        <text>四</text><text>五</text><text>六</text>
      </view>
      <view class="cal-days">
        <view
          wx:for="{{calendarDays}}"
          wx:key="index"
          class="cal-day {{item.checkin ? 'day-checked' : ''}} {{item.today ? 'day-today' : ''}} {{!item.day ? 'day-empty' : ''}}"
        >
          <view class="day-num">{{item.day}}</view>
          <view class="day-star" wx:if="{{item.checkin}}">★</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 设置 -->
  <view class="section">
    <view class="section-header">
      <view class="section-title">设置</view>
    </view>
    <view class="settings-card">
      <view class="setting-row" bindtap="clearData">
        <view class="setting-left">
          <text class="setting-icon">🔄</text>
          <text class="setting-text">重新开始</text>
        </view>
        <text class="setting-arrow">›</text>
      </view>
      <view class="row-divider"></view>
      <view class="setting-row">
        <view class="setting-left">
          <text class="setting-icon">☀️</text>
          <text class="setting-text">关于失恋晴天</text>
        </view>
        <text class="setting-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="footer">分手而已，雨过天会晴</view>
</view>
