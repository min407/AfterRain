/* 主页 v2 - 玻璃瓶 · 进度 · 打卡 */
.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(168deg, #F4F0FF 0%, #EDF5FF 60%, #F0F8FF 100%);
  padding: 16px 20px 32px;
  box-sizing: border-box;
}

/* ——— 顶部 Stats ——— */
.header {
  background: #FFFFFF;
  border-radius: 20px;
  padding: 20px 24px 16px;
  box-shadow: 0 2px 12px rgba(155,142,196,0.1), 0 8px 24px rgba(155,142,196,0.06);
  margin-bottom: 24px;
}
.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-bottom: 18px;
}
.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}
.stat-sep {
  width: 1px;
  height: 32px;
  background: #EDE8F8;
}
.stat-num {
  font-size: 28px;
  font-weight: 700;
  color: #2D2B55;
  line-height: 1;
  margin-bottom: 6px;
}
.stat-target { color: #C4BDE4; }
.stat-streak { color: #7DD3A8; }
.stat-label {
  font-size: 12px;
  color: #B0B0CC;
  letter-spacing: 0.5px;
}

/* 进度条 */
.progress-wrap {
  display: flex;
  align-items: center;
  gap: 10px;
}
.progress-track {
  flex: 1;
  height: 8px;
  background: #EEE9F8;
  border-radius: 4px;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #B8A9E8 0%, #8EC5FC 100%);
  border-radius: 4px;
  transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}
.progress-pct {
  font-size: 12px;
  color: #9B8EC4;
  font-weight: 600;
  width: 36px;
  text-align: right;
}

/* ——— 玻璃瓶区域 ——— */
.bottle-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.bottle-outer {
  position: relative;
  width: 200px;
  height: 290px;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  margin-bottom: 24px;
}
.bottle-glow-ring {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 220px; height: 220px;
  background: radial-gradient(circle, rgba(155,142,196,0.14) 0%, transparent 68%);
  border-radius: 50%;
  animation: ring-pulse 3.5s infinite ease-in-out;
}
@keyframes ring-pulse {
  0%, 100% { transform: translate(-50%,-50%) scale(0.9); opacity: 0.7; }
  50%       { transform: translate(-50%,-50%) scale(1.1); opacity: 1; }
}
.bottle {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 1;
}

/* 瓶口 */
.bottle-neck {
  width: 54px; height: 34px;
  background: linear-gradient(180deg,
    rgba(255,255,255,0.96) 0%,
    rgba(218,210,248,0.88) 100%);
  border-radius: 10px 10px 0 0;
  border: 1.5px solid rgba(155,142,196,0.2);
  border-bottom: none;
  display: flex;
  justify-content: center;
  align-items: flex-start;
  padding-top: 6px;
}
.bottle-cap {
  width: 44px; height: 11px;
  background: linear-gradient(90deg, #C8BAEC, #A4C6F8, #C8BAEC);
  border-radius: 5px;
}

/* 瓶身 */
.bottle-body {
  width: 170px; height: 240px;
  background: linear-gradient(155deg,
    rgba(255,255,255,0.9) 0%,
    rgba(234,226,254,0.7) 35%,
    rgba(220,236,255,0.72) 68%,
    rgba(255,255,255,0.8) 100%);
  border-radius: 28px 28px 52px 52px;
  border: 1.5px solid rgba(155,142,196,0.18);
  position: relative;
  overflow: hidden;
  box-shadow:
    inset 0 0 32px rgba(255,255,255,0.55),
    0 20px 52px rgba(155,142,196,0.2),
    0 4px 14px rgba(155,142,196,0.08);
}
.bottle-shine {
  position: absolute;
  left: 16px; top: 22px;
  width: 15px; height: 66%;
  background: linear-gradient(180deg, rgba(255,255,255,0.7) 0%, transparent 100%);
  border-radius: 8px;
}

/* 瓶内星星 */
.stars-container {
  position: absolute;
  inset: 0;
}
.star-item {
  position: absolute;
  animation: star-float 3s infinite ease-in-out;
}
.star-icon {
  text-shadow: 0 0 10px currentColor;
  display: block;
  animation: star-twinkle 2.5s infinite ease-in-out;
}
@keyframes star-float {
  0%, 100% { transform: translateY(0); }
  50%       { transform: translateY(-7px); }
}
@keyframes star-twinkle {
  0%, 100% { opacity: 0.6; transform: scale(0.88); }
  50%       { opacity: 1;   transform: scale(1.12); }
}

/* ——— AI 寄语卡片 ——— */
.quote-card {
  background: #FFFFFF;
  border-radius: 18px;
  padding: 16px 22px;
  max-width: 300px;
  width: 100%;
  box-shadow: 0 2px 10px rgba(155,142,196,0.1), 0 6px 20px rgba(155,142,196,0.06);
  position: relative;
}
.quote-mark {
  font-size: 36px;
  color: #E8E2F8;
  line-height: 1;
  position: absolute;
  top: 6px; left: 14px;
  font-family: Georgia, serif;
}
.quote-text {
  font-size: 14px;
  color: #6B6B8D;
  line-height: 1.7;
  display: block;
  padding-left: 20px;
  padding-top: 4px;
  letter-spacing: 0.3px;
}

/* ——— 底部打卡按钮 ——— */
.bottom-action {
  padding-top: 24px;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.checkin-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 220px;
  height: 56px;
  background: linear-gradient(135deg, #9B8EC4 0%, #7AB8FA 100%);
  border-radius: 28px;
  border: none;
  box-shadow: 0 12px 32px rgba(142,197,252,0.42);
  transition: all 0.25s ease;
}
.checkin-btn:active {
  transform: scale(0.96);
  box-shadow: 0 5px 14px rgba(142,197,252,0.3);
}
.checkin-icon { font-size: 20px; }
.checkin-text {
  font-size: 18px;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 1px;
}
.checkin-hint {
  font-size: 12px;
  color: #C0BAD6;
  margin-top: 10px;
  letter-spacing: 0.5px;
}
