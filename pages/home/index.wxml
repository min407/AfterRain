<view class="container">
  <!-- 顶部状态栏 -->
  <view class="header">
    <view class="stats-row">
      <view class="stat-item">
        <view class="stat-num">{{day}}</view>
        <view class="stat-label">当前天</view>
      </view>
      <view class="stat-sep"></view>
      <view class="stat-item">
        <view class="stat-num stat-target">{{targetDays}}</view>
        <view class="stat-label">目标天</view>
      </view>
      <view class="stat-sep"></view>
      <view class="stat-item">
        <view class="stat-num stat-streak">{{streak}}</view>
        <view class="stat-label">连续记录</view>
      </view>
    </view>
    <view class="progress-wrap">
      <view class="progress-track">
        <view class="progress-fill" style="width: {{progress}}%;"></view>
      </view>
      <view class="progress-pct">{{progress}}%</view>
    </view>
  </view>

  <!-- 玻璃罐主视觉 -->
  <view class="bottle-section">
    <view class="bottle-outer">
      <view class="bottle-glow-ring"></view>
      <view class="jar">
        <!-- 彩虹全息盖（带掀盖动画） -->
        <view class="jar-lid {{lidOpen ? 'jar-lid--open' : ''}}">
          <view class="jar-lid-top"></view>
          <view class="jar-lid-ring"></view>
        </view>
        <!-- 窄口 + 肩部过渡 -->
        <view class="jar-neck"></view>
        <view class="jar-shoulder"></view>
        <!-- 直筒玻璃罐身（带闪光） -->
        <view class="jar-body {{jarFlash ? 'jar-body--flash' : ''}}">
          <view class="jar-shine"></view>
          <view class="stars-container">
            <view
              wx:for="{{stars}}"
              wx:key="index"
              class="star-item {{item.isNew ? 'star-item--new' : ''}}"
              style="left: {{item.x}}%; top: {{item.y}}%; animation-delay: {{item.delay}}s;"
            >
              <view class="star-shape" style="background: radial-gradient(circle at 38% 32%, {{item.colorLight}}, {{item.color}}); width: {{item.size}}px; height: {{item.size}}px;"></view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 飞行中的星星（fixed 定位，脱离文档流） -->
  <view
    wx:if="{{flyingStar && flyingStar.visible}}"
    class="flying-star"
    style="left:{{flyingStar.left}}px; top:{{flyingStar.top}}px; transform: translate({{flyingStar.flying ? flyingStar.deltaX : 0}}px, {{flyingStar.flying ? flyingStar.deltaY : 0}}px) scale({{flyingStar.flying ? 0.65 : 1.2}}) rotate({{flyingStar.flying ? 200 : 0}}deg); background: radial-gradient(circle at 38% 32%, {{flyingStar.colorLight}}, {{flyingStar.color}});"
  ></view>

  <!-- 可输入卡片 -->
  <view class="memo-card">
    <textarea
      class="memo-input"
      placeholder="今天还好吗？有什么想对TA说的话，写下来，折成星星放进罐子里吧..."
      placeholder-class="memo-placeholder"
      auto-height="true"
      cursor-spacing="12"
      maxlength="200"
      value="{{memoText}}"
      bindinput="onInput"
    ></textarea>
  </view>

  <!-- 折星星按钮 -->
  <view class="bottom-action">
    <view class="btn-row">
      <button class="checkin-btn checkin-btn--primary" bindtap="foldStar">
        <text class="checkin-icon">✨</text>
        <text class="checkin-text">说给星星听</text>
      </button>
      <button class="checkin-btn checkin-btn--ghost" bindtap="justCheckin">
        <text class="checkin-icon">📍</text>
        <text class="checkin-text">只想打卡</text>
      </button>
    </view>
    <view class="checkin-hint">写下一句，瓶子就亮一点；不想写也可以直接打卡</view>
  </view>
</view>
