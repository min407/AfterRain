/* 备忘录页 v2 - 打卡模式 + 清醒备忘 */
.container {
  min-height: 100vh;
  background: linear-gradient(168deg, #F4F0FF 0%, #EDF5FF 100%);
}

/* ===== 打卡模式 ===== */
.checkin-mode {
  padding: 40px 20px 32px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 打卡头部 */
.checkin-hero {
  text-align: center;
  margin-bottom: 28px;
}
.checkin-emoji {
  font-size: 44px;
  margin-bottom: 12px;
  display: block;
}
.checkin-title {
  font-size: 24px;
  font-weight: 700;
  color: #2D2B55;
  margin-bottom: 6px;
  letter-spacing: 1px;
}
.checkin-day {
  font-size: 15px;
  color: #9B8EC4;
  font-weight: 500;
}

/* 打卡卡片 */
.checkin-card {
  width: 100%;
  max-width: 360px;
  background: #FFFFFF;
  border-radius: 24px;
  padding: 28px 22px;
  box-shadow: 0 4px 16px rgba(155,142,196,0.12), 0 12px 32px rgba(155,142,196,0.07);
}

.q-block { margin-bottom: 24px; }
.q-label {
  font-size: 16px;
  font-weight: 600;
  color: #2D2B55;
  margin-bottom: 16px;
  letter-spacing: 0.3px;
}

/* 联系 TA 选项 */
.q-options {
  display: flex;
  gap: 12px;
}
.q-opt {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  padding: 18px 8px;
  background: #F8F5FF;
  border-radius: 16px;
  border: 2px solid transparent;
  transition: all 0.2s ease;
}
.q-opt:active { transform: scale(0.96); }
.opt-selected {
  background: #F0ECFF;
  border-color: #9B8EC4;
}
.opt-warn.opt-selected {
  background: #FFF4F0;
  border-color: #FFB088;
}
.opt-icon { font-size: 26px; }
.opt-text {
  font-size: 14px;
  color: #6B6B8D;
  font-weight: 500;
}
.opt-selected .opt-text { color: #2D2B55; }

.q-divider {
  height: 1px;
  background: #F0EBF8;
  margin: 0 0 24px;
}

/* 情绪选择 */
.mood-row {
  display: flex;
  justify-content: space-between;
}
.mood-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 7px;
  padding: 12px 6px;
  border-radius: 14px;
  border: 2px solid transparent;
  transition: all 0.18s ease;
  flex: 1;
}
.mood-item:active { transform: scale(0.93); }
.mood-selected {
  background: #F0ECFF;
  border-color: #C4B8E8;
}
.mood-icon { font-size: 28px; }
.mood-label {
  font-size: 11px;
  color: #B0B0CC;
  font-weight: 500;
}
.mood-selected .mood-label { color: #9B8EC4; }

/* 提交按钮 */
.submit-btn {
  width: 100%;
  height: 56px;
  background: linear-gradient(135deg, #9B8EC4 0%, #7AB8FA 100%);
  border-radius: 28px;
  color: #FFFFFF;
  font-size: 17px;
  font-weight: 700;
  border: none;
  margin-top: 8px;
  box-shadow: 0 10px 28px rgba(142,197,252,0.38);
  letter-spacing: 1px;
}
.submit-btn::after { border: none; }
.submit-btn[disabled] {
  opacity: 0.45;
  box-shadow: none;
}

/* ===== 备忘录模式 ===== */
.memo-mode {
  display: flex;
  flex-direction: column;
  height: 100vh;
  position: relative;
}

.memo-header {
  padding: 28px 20px 20px;
  background: linear-gradient(180deg, #F4F0FF 0%, transparent 100%);
}
.memo-title {
  font-size: 24px;
  font-weight: 700;
  color: #2D2B55;
  margin-bottom: 5px;
  letter-spacing: 0.5px;
}
.memo-sub {
  font-size: 14px;
  color: #B4B0CC;
}

/* 列表 */
.memo-list {
  flex: 1;
  padding: 0 16px;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 20px;
}
.empty-icon { font-size: 46px; margin-bottom: 14px; }
.empty-text {
  font-size: 16px;
  font-weight: 600;
  color: #C8C4D8;
  margin-bottom: 8px;
}
.empty-hint {
  font-size: 13px;
  color: #D0CCDC;
  text-align: center;
  line-height: 1.6;
}

/* 备忘条目 */
.memo-item {
  display: flex;
  align-items: stretch;
  background: #FFFFFF;
  border-radius: 16px;
  margin-bottom: 12px;
  overflow: hidden;
  box-shadow: 0 2px 10px rgba(155,142,196,0.09), 0 1px 3px rgba(0,0,0,0.03);
}
.memo-accent {
  width: 4px;
  background: linear-gradient(180deg, #B8A9E8 0%, #8EC5FC 100%);
  flex-shrink: 0;
  border-radius: 2px 0 0 2px;
}
.memo-body {
  flex: 1;
  padding: 14px 12px;
}
.memo-content {
  font-size: 15px;
  color: #2D2B55;
  line-height: 1.55;
  display: block;
  margin-bottom: 5px;
}
.memo-time {
  font-size: 12px;
  color: #C0BCCE;
  display: block;
}
.memo-del {
  padding: 14px 16px;
  font-size: 14px;
  color: #D4D0E0;
  display: flex;
  align-items: center;
}

/* 浮动按钮 */
.fab {
  position: fixed;
  bottom: 100px;
  right: 24px;
  width: 58px; height: 58px;
  background: linear-gradient(135deg, #9B8EC4 0%, #8EC5FC 100%);
  border-radius: 29px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8px 24px rgba(142,197,252,0.45);
  z-index: 10;
}
.fab:active { transform: scale(0.93); }
.fab-icon {
  font-size: 30px;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
  margin-top: -2px;
}

/* 添加输入面板 */
.add-sheet {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #FFFFFF;
  border-radius: 24px 24px 0 0;
  padding: 20px 20px 48px;
  box-shadow: 0 -6px 30px rgba(155,142,196,0.16);
  z-index: 20;
}
.add-sheet-title {
  font-size: 16px;
  font-weight: 600;
  color: #2D2B55;
  margin-bottom: 14px;
  text-align: center;
}
.add-input-field {
  width: 100%;
  background: #F4F0FD;
  border: 1.5px solid #E6E0F8;
  border-radius: 16px;
  padding: 14px 16px;
  font-size: 15px;
  color: #2D2B55;
  margin-bottom: 14px;
  box-sizing: border-box;
  min-height: 50px;
}
.add-confirm-btn {
  width: 100%;
  height: 54px;
  background: linear-gradient(135deg, #9B8EC4 0%, #7AB8FA 100%);
  border-radius: 27px;
  color: #FFFFFF;
  font-size: 17px;
  font-weight: 700;
  border: none;
  box-shadow: 0 8px 22px rgba(142,197,252,0.36);
  letter-spacing: 2px;
}
.add-confirm-btn::after { border: none; }
